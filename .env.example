# Local dev points at the Postgres container from docker-compose.yml
DATABASE_URL="postgresql://stronglog:stronglog@localhost:5432/stronglog"

# --- AI Coach (Phase 1+) ---
# Portkey gateway → Claude. The model is routed through a saved integration as
# `@<PORTKEY_INTEGRATION>/<model>` (inline providers are blocked org-wide).
PORTKEY_API_KEY=""
PORTKEY_INTEGRATION="david-stahl"   # your Portkey integration slug
# Optional overrides:
# COACH_MODEL="claude-sonnet-4-6"   # or claude-opus-4-8 (bare id; prefixed automatically)
# PORTKEY_VIRTUAL_KEY="..."          # only if your setup uses a virtual-key header instead

# --- Email reminders / digest (Phase 2) ---
# RESEND_API_KEY=""
# COACH_FROM_EMAIL="coach@yourdomain.com"   # a verified Resend sender
# COACH_REMINDER_TO="you@example.com"

# --- Scheduler (Phase 2) ---
# CRON_SECRET=""   # protects POST /api/coach/tick
